generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Prompt {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Generation {
  id         Int      @id @default(autoincrement())
  team       String
  type       String
  side       String?
  playerName String?
  number     String?
  pose       String?
  model      String
  imagePath  String
  createdAt  DateTime @default(now())
}
