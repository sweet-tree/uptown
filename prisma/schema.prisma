generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Sports catalog ─────────────────────────────────────────────────────────────

model Sport {
  id        Int      @id @default(autoincrement())
  slug      String   @unique   // "nfl" | "nba" | "soccer" | "baseball"
  name      String
  active    Boolean  @default(true)
  teams     Team[]
  createdAt DateTime @default(now())
}

model Team {
  id               Int          @id @default(autoincrement())
  abbreviation     String
  sportId          Int
  sport            Sport        @relation(fields: [sportId], references: [id])
  name             String
  city             String
  primaryHex       String
  secondaryHex     String
  stadiumName      String
  stadiumPrompt    String       @db.Text
  skylinePrompt    String       @db.Text
  skyPrompt        String       @db.Text
  jerseyPrompt     String       @db.Text
  pantsPrompt      String       @db.Text
  helmetPrompt     String       @db.Text
  numberStyle      String
  logoPrompt       String       @db.Text
  active           Boolean       @default(true)
  cardPlayers      CardPlayer[]
  rosterEntries    RosterEntry[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([sportId, abbreviation])
}

/// Full team roster for UI + name/# lookups (optional per team; DAL has full data in seed)
model RosterEntry {
  id         Int    @id @default(autoincrement())
  teamId     Int
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name       String
  number     String
  position   String
  sortOrder  Int    @default(0)

  @@index([teamId])
}

model CardPlayer {
  id         Int    @id @default(autoincrement())
  teamId     Int
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name       String
  number     String
  position   String
  side       String            // "left" | "right"
  pose       String @default("auto")
  ball       String @default("auto")
  order      Int    @default(0) // for consistent ordering
}

// ── Prompt overrides ───────────────────────────────────────────────────────────

model Prompt {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  text      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Generation log ─────────────────────────────────────────────────────────────

model Generation {
  id         Int      @id @default(autoincrement())
  team       String
  type       String
  side       String?
  playerName String?
  number     String?
  pose       String?
  model      String
  imagePath  String
  createdAt  DateTime @default(now())
}
